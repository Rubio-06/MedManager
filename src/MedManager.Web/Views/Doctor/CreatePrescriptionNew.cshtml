@model MedManager.Web.Models.ViewModels.CreatePrescriptionViewModel

@{
    ViewData["Title"] = "Nouvelle Ordonnance";
    Layout = "_ManagementLayout";
}

<!-- Breadcrumb Navigation -->
<div class="flex items-center text-sm text-gray-600 mb-6">
    <a asp-action="Patients" class="hover:text-indigo-600 transition duration-150">Patients</a>
    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a asp-action="PatientProfile" asp-route-id="@Model.PatientId" class="hover:text-indigo-600 transition duration-150">
        @Model.PatientFirstName @Model.PatientLastName
    </a>
    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-900">Nouvelle ordonnance</span>
</div>

<div class="max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Nouvelle Ordonnance</h1>
        <p class="text-gray-600 mt-1">Créer une ordonnance pour @Model.PatientFirstName @Model.PatientLastName</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Section gauche - Informations patient -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Informations patient -->
            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    Patient
                </h2>
                <div class="space-y-3 text-sm">
                    <div>
                        <p class="text-gray-500">Nom complet</p>
                        <p class="font-medium text-gray-900">@Model.PatientFirstName @Model.PatientLastName</p>
                    </div>
                    <div>
                        <p class="text-gray-500">Âge</p>
                        <p class="font-medium text-gray-900">@Model.PatientAge ans</p>
                    </div>
                    <div>
                        <p class="text-gray-500">Email</p>
                        <p class="font-medium text-gray-900">@Model.PatientEmail</p>
                    </div>
                    <div>
                        <p class="text-gray-500">N° Sécurité sociale</p>
                        <p class="font-medium text-gray-900 font-mono">@Model.SocialSecurityNumber</p>
                    </div>
                </div>
            </div>

            <!-- Allergies du patient -->
            @if (Model.PatientAllergies.Any())
            {
                <div class="bg-red-50 border-2 border-red-200 rounded-lg p-6">
                    <h2 class="text-lg font-semibold text-red-900 mb-3 flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                        </svg>
                        Allergies
                    </h2>
                    <ul class="space-y-2">
                        @foreach (var allergy in Model.PatientAllergies)
                        {
                            <li class="text-sm text-red-800 font-medium">• @allergy.Name</li>
                        }
                    </ul>
                </div>
            }
        </div>

        <!-- Section droite - Ordonnance -->
        <div class="lg:col-span-2">
            <div class="bg-white rounded-lg shadow">
                <!-- Header ordonnance -->
                <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                    <h2 class="text-lg font-semibold text-gray-900">Médicaments prescrits</h2>
                    <button onclick="openMedicineModal()" class="inline-flex items-center px-3 py-1.5 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition duration-150">
                        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                        Ajouter un médicament
                    </button>
                </div>

                <!-- Liste des médicaments -->
                <div class="p-6">
                    <div id="prescribedMedicines" class="space-y-3">
                        <!-- Les médicaments seront ajoutés ici dynamiquement -->
                    </div>

                    <div id="emptyState" class="text-center py-12">
                        <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                        </svg>
                        <p class="text-gray-600 mb-4">Aucun médicament prescrit</p>
                        <button onclick="openMedicineModal()" class="inline-flex items-center px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition duration-150">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            Ajouter le premier médicament
                        </button>
                    </div>
                </div>

                <!-- Footer avec boutons d'action -->
                <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex justify-end gap-3">
                    <a asp-action="PatientProfile" asp-route-id="@Model.PatientId" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition duration-150 font-medium">
                        Annuler
                    </a>
                    <button onclick="submitPrescription()" id="submitBtn" disabled class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition duration-150 font-medium disabled:bg-gray-300 disabled:cursor-not-allowed">
                        Créer l'ordonnance
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Ajouter Médicament -->
<div id="medicineModal" class="fixed inset-0 bg-black/50 z-50 items-center justify-center p-4" style="display: none;" onclick="handleModalOverlayClick(event, 'medicineModal')">
    <div class="bg-white rounded-lg shadow-xl max-w-3xl w-full max-h-[90vh] flex flex-col" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
            <h3 class="text-xl font-semibold text-gray-900">Ajouter un médicament</h3>
            <button onclick="closeMedicineModal()" class="text-gray-400 hover:text-gray-600 transition duration-150">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Recherche -->
        <div class="px-6 py-4 border-b border-gray-200">
            <div class="relative">
                <input type="text" id="medicineSearch" placeholder="Rechercher un médicament..." 
                       class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                       onkeyup="filterMedicines()">
                <svg class="w-5 h-5 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
            </div>
        </div>

        <!-- Liste des médicaments -->
        <div class="flex-1 overflow-y-auto px-6 py-4">
            <div id="medicineList" class="space-y-2">
                @foreach (var medicine in Model.AvailableMedicines)
                {
                    var hasConflict = medicine.HasAllergyConflict;
                    var cardClass = hasConflict 
                        ? "medicine-item p-3 border-2 border-red-300 bg-red-50 rounded-lg cursor-not-allowed opacity-60" 
                        : "medicine-item p-3 border-2 border-gray-200 rounded-lg cursor-pointer hover:border-green-400 hover:bg-green-50 transition duration-150";
                    
                    <div class="@cardClass"
                         data-medicine-id="@medicine.Id"
                         data-medicine-name="@medicine.Name.ToLower()"
                         data-medicine-composition="@(medicine.Composition?.ToLower() ?? "")"
                         data-has-conflict="@hasConflict.ToString().ToLower()"
                         onclick="selectMedicine(@medicine.Id, '@medicine.Name', '@(medicine.Composition ?? "")', @hasConflict.ToString().ToLower())">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <div class="flex items-center gap-2">
                                    <p class="font-medium text-gray-900">@medicine.Name</p>
                                    @if (hasConflict)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                            </svg>
                                            Allergie
                                        </span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(medicine.Composition))
                                {
                                    <p class="text-sm text-gray-600 mt-1">@medicine.Composition</p>
                                }
                            </div>
                            @if (!hasConflict)
                            {
                                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                                </svg>
                            }
                            else
                            {
                                <svg class="w-5 h-5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M13.477 14.89A6 6 0 015.11 6.524l8.367 8.368zm1.414-1.414L6.524 5.11a6 6 0 018.367 8.367zM18 10a8 8 0 11-16 0 8 8 0 0116 0z" clip-rule="evenodd"/>
                                </svg>
                            }
                        </div>
                    </div>
                }
            </div>
            <div id="noMedicineResults" class="hidden text-center py-8">
                <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-gray-600">Aucun médicament trouvé</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal Détails Médicament -->
<div id="medicineDetailsModal" class="fixed inset-0 bg-black/50 z-50 items-center justify-center p-4" style="display: none;" onclick="handleModalOverlayClick(event, 'medicineDetailsModal')">
    <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full" onclick="event.stopPropagation()">
        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
            <h3 class="text-xl font-semibold text-gray-900" id="modalMedicineName"></h3>
            <button onclick="closeMedicineDetailsModal()" class="text-gray-400 hover:text-gray-600 transition duration-150">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Composition -->
        <div class="px-6 py-3 bg-gray-50 border-b border-gray-200">
            <p class="text-sm text-gray-600" id="modalMedicineComposition"></p>
        </div>

        <!-- Formulaire -->
        <form id="medicineDetailsForm" class="p-6 space-y-4">
            <input type="hidden" id="selectedMedicineId" />

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Quantité *</label>
                <input type="number" id="medicineQuantity" min="1" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                       placeholder="Ex: 30">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Dosage *</label>
                <input type="text" id="medicineDosage" required
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                       placeholder="Ex: 1 comprimé matin et soir">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Durée</label>
                <input type="text" id="medicineDuration"
                       class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                       placeholder="Ex: 7 jours, 2 semaines">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Conseils d'utilisation</label>
                <textarea id="medicineInstructions" rows="3"
                          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                          placeholder="Ex: À prendre pendant les repas"></textarea>
            </div>
        </form>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex justify-end gap-3">
            <button onclick="closeMedicineDetailsModal()" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition duration-150 font-medium">
                Annuler
            </button>
            <button onclick="addMedicineToPrescription()" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition duration-150 font-medium">
                Ajouter à l'ordonnance
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let prescribedMedicines = [];
        let editingMedicineIndex = null;

        function handleModalOverlayClick(event, modalId) {
            if (event.target.id === modalId) {
                if (modalId === 'medicineModal') {
                    closeMedicineModal();
                } else if (modalId === 'medicineDetailsModal') {
                    closeMedicineDetailsModal();
                }
            }
        }

        function openMedicineModal() {
            document.getElementById('medicineModal').style.display = 'flex';
            document.getElementById('medicineSearch').value = '';
            filterMedicines();
            updateMedicineListState();
        }

        function closeMedicineModal() {
            document.getElementById('medicineModal').style.display = 'none';
        }

        function updateMedicineListState() {
            const medicineItems = document.querySelectorAll('.medicine-item');
            const prescribedIds = prescribedMedicines.map(m => m.medicineId);

            medicineItems.forEach(item => {
                const medicineId = parseInt(item.getAttribute('data-medicine-id'));
                const hasConflict = item.getAttribute('data-has-conflict') === 'true';
                const isAlreadyPrescribed = prescribedIds.includes(medicineId);

                if (isAlreadyPrescribed) {
                    item.classList.remove('hover:border-green-400', 'hover:bg-green-50', 'cursor-pointer');
                    item.classList.add('bg-gray-100', 'opacity-50', 'cursor-not-allowed', 'border-gray-300');
                    item.onclick = function(e) {
                        e.preventDefault();
                        showWarningToast('Ce médicament est déjà dans l\'ordonnance');
                    };
                } else if (hasConflict) {
                    // Already styled by server, just update onclick
                    item.onclick = function(e) {
                        e.preventDefault();
                        showErrorToast('⚠️ ATTENTION : Le patient est allergique à un composant de ce médicament !', 5000);
                    };
                }
            });
        }

        function filterMedicines() {
            const searchTerm = document.getElementById('medicineSearch').value.toLowerCase();
            const medicineItems = document.querySelectorAll('.medicine-item');
            let visibleCount = 0;

            medicineItems.forEach(item => {
                const name = item.getAttribute('data-medicine-name');
                const composition = item.getAttribute('data-medicine-composition') || '';
                
                if (name.includes(searchTerm) || composition.includes(searchTerm)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('noMedicineResults').classList.toggle('hidden', visibleCount > 0);
        }

        function selectMedicine(medicineId, medicineName, composition, hasConflict) {
            // Vérifier si déjà prescrit
            if (prescribedMedicines.some(m => m.medicineId === medicineId)) {
                showWarningToast('Ce médicament est déjà dans l\'ordonnance');
                return;
            }

            // Vérifier le conflit d'allergie
            if (hasConflict) {
                showErrorToast('⚠️ ATTENTION : Le patient est allergique à un composant de ce médicament !', 5000);
                return;
            }

            closeMedicineModal();
            
            // Ouvrir le modal de détails
            document.getElementById('modalMedicineName').textContent = medicineName;
            document.getElementById('modalMedicineComposition').textContent = composition || 'Composition non spécifiée';
            document.getElementById('selectedMedicineId').value = medicineId;
            
            // Réinitialiser le formulaire
            document.getElementById('medicineQuantity').value = '';
            document.getElementById('medicineDosage').value = '';
            document.getElementById('medicineDuration').value = '';
            document.getElementById('medicineInstructions').value = '';
            
            document.getElementById('medicineDetailsModal').style.display = 'flex';
        }

        function closeMedicineDetailsModal() {
            document.getElementById('medicineDetailsModal').style.display = 'none';
            editingMedicineIndex = null;
        }

        function addMedicineToPrescription() {
            const medicineId = document.getElementById('selectedMedicineId').value;
            const medicineName = document.getElementById('modalMedicineName').textContent;
            const composition = document.getElementById('modalMedicineComposition').textContent;
            const quantity = document.getElementById('medicineQuantity').value;
            const dosage = document.getElementById('medicineDosage').value;
            const duration = document.getElementById('medicineDuration').value;
            const instructions = document.getElementById('medicineInstructions').value;

            if (!quantity || !dosage) {
                showErrorToast('Veuillez remplir les champs obligatoires (Quantité et Dosage)');
                return;
            }

            const medicine = {
                medicineId: parseInt(medicineId),
                medicineName,
                composition,
                quantity: parseInt(quantity),
                dosage,
                duration,
                instructions
            };

            if (editingMedicineIndex !== null) {
                prescribedMedicines[editingMedicineIndex] = medicine;
                editingMedicineIndex = null;
                showSuccessToast('Médicament modifié avec succès');
            } else {
                prescribedMedicines.push(medicine);
                showSuccessToast('Médicament ajouté à l\'ordonnance');
            }

            updatePrescriptionList();
            closeMedicineDetailsModal();
        }

        function updatePrescriptionList() {
            const container = document.getElementById('prescribedMedicines');
            const emptyState = document.getElementById('emptyState');
            const submitBtn = document.getElementById('submitBtn');

            if (prescribedMedicines.length === 0) {
                container.innerHTML = '';
                emptyState.style.display = 'block';
                submitBtn.disabled = true;
                return;
            }

            emptyState.style.display = 'none';
            submitBtn.disabled = false;

            container.innerHTML = prescribedMedicines.map((med, index) => `
                <div class="border-2 border-gray-200 rounded-lg p-4 hover:border-gray-300 transition duration-150">
                    <div class="flex items-start justify-between">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-2">
                                <h4 class="font-semibold text-gray-900">${med.medicineName}</h4>
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
                                    ${med.quantity} unité${med.quantity > 1 ? 's' : ''}
                                </span>
                            </div>
                            ${med.composition && med.composition !== 'Composition non spécifiée' ? `<p class="text-sm text-gray-600 mb-2">${med.composition}</p>` : ''}
                            <div class="space-y-1 text-sm">
                                <p><span class="font-medium text-gray-700">Dosage:</span> ${med.dosage}</p>
                                ${med.duration ? `<p><span class="font-medium text-gray-700">Durée:</span> ${med.duration}</p>` : ''}
                                ${med.instructions ? `<p><span class="font-medium text-gray-700">Instructions:</span> ${med.instructions}</p>` : ''}
                            </div>
                        </div>
                        <div class="flex gap-2 ml-4">
                            <button onclick="editMedicine(${index})" class="text-blue-600 hover:text-blue-800 transition duration-150">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </button>
                            <button onclick="removeMedicine(${index})" class="text-red-600 hover:text-red-800 transition duration-150">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function editMedicine(index) {
            const med = prescribedMedicines[index];
            editingMedicineIndex = index;

            document.getElementById('modalMedicineName').textContent = med.medicineName;
            document.getElementById('modalMedicineComposition').textContent = med.composition;
            document.getElementById('selectedMedicineId').value = med.medicineId;
            document.getElementById('medicineQuantity').value = med.quantity;
            document.getElementById('medicineDosage').value = med.dosage;
            document.getElementById('medicineDuration').value = med.duration || '';
            document.getElementById('medicineInstructions').value = med.instructions || '';

            document.getElementById('medicineDetailsModal').style.display = 'flex';
        }

        function removeMedicine(index) {
            const med = prescribedMedicines[index];
            showConfirmDialog(
                'Retirer le médicament',
                `Êtes-vous sûr de vouloir retirer "<strong>${med.medicineName}</strong>" de l'ordonnance ?`,
                'Retirer',
                'Annuler',
                function() {
                    prescribedMedicines.splice(index, 1);
                    updatePrescriptionList();
                    updateMedicineListState();
                    showInfoToast('Médicament retiré de l\'ordonnance');
                }
            );
        }

        function submitPrescription() {
            if (prescribedMedicines.length === 0) {
                showErrorToast('Veuillez ajouter au moins un médicament');
                return;
            }

            console.log('Médicaments à envoyer:', prescribedMedicines);

            // Créer un formulaire pour soumettre les données
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("CreatePrescription", "Doctor")';

            // Ajouter le patient ID
            const patientInput = document.createElement('input');
            patientInput.type = 'hidden';
            patientInput.name = 'patientId';
            patientInput.value = '@Model.PatientId';
            form.appendChild(patientInput);

            // Ajouter les médicaments en JSON
            const medicinesInput = document.createElement('input');
            medicinesInput.type = 'hidden';
            medicinesInput.name = 'medicines';
            medicinesInput.value = JSON.stringify(prescribedMedicines);
            form.appendChild(medicinesInput);

            console.log('Valeur JSON envoyée:', medicinesInput.value);

            // Ajouter le formulaire au body et le soumettre
            document.body.appendChild(form);
            form.submit();
        }
    </script>
}
