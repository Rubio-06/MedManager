@model MedManager.Web.Models.ViewModels.CreatePatientViewModel

@{
    ViewData["Title"] = "Nouveau Patient";
    Layout = "_ManagementLayout";
}

<div class="max-w-4xl mx-auto">
    <!-- Breadcrumb -->
    <div class="flex items-center text-sm text-gray-600 mb-6">
        <a asp-action="Patients" class="hover:text-indigo-600 transition duration-150">Patients</a>
        <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-gray-900">Ajouter</span>
    </div>

    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Nouveau Patient</h1>
        <p class="mt-2 text-sm text-gray-600">Créez un nouveau patient qui vous sera automatiquement assigné</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <form asp-action="CreatePatient" method="post">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Prénom -->
                <div>
                    <label asp-for="FirstName" class="block text-sm font-medium text-gray-700 mb-2"></label>
                    <input asp-for="FirstName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" placeholder="Jean" />
                    <span asp-validation-for="FirstName" class="text-red-600 text-sm"></span>
                </div>

                <!-- Nom -->
                <div>
                    <label asp-for="LastName" class="block text-sm font-medium text-gray-700 mb-2"></label>
                    <input asp-for="LastName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" placeholder="Dupont" />
                    <span asp-validation-for="LastName" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <!-- Email -->
            <div class="mb-6">
                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <input asp-for="Email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" placeholder="patient@example.com" />
                <span asp-validation-for="Email" class="text-red-600 text-sm"></span>
            </div>

            <!-- Mot de passe -->
            <div class="mb-6">
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <input asp-for="Password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" placeholder="Au moins 6 caractères" />
                <span asp-validation-for="Password" class="text-red-600 text-sm"></span>
                <p class="text-sm text-gray-500 mt-1">Le patient pourra se connecter avec cet email et mot de passe</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Date de naissance -->
                <div>
                    <label asp-for="DateBirthday" class="block text-sm font-medium text-gray-700 mb-2"></label>
                    <input asp-for="DateBirthday" type="date" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" />
                    <span asp-validation-for="DateBirthday" class="text-red-600 text-sm"></span>
                </div>

                <!-- Sexe -->
                <div>
                    <label asp-for="Gender" class="block text-sm font-medium text-gray-700 mb-2"></label>
                    <select asp-for="Gender" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600">
                        <option value="">Sélectionner...</option>
                        <option value="0">Homme</option>
                        <option value="1">Femme</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-red-600 text-sm"></span>
                </div>
            </div>

            <!-- Numéro de sécurité sociale -->
            <div class="mb-6">
                <label asp-for="SocialSecurityNumber" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <input asp-for="SocialSecurityNumber" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 transition duration-150" placeholder="1 23 45 67 890 123 45" maxlength="15" />
                <span asp-validation-for="SocialSecurityNumber" class="text-red-600 text-sm"></span>
                <p class="text-sm text-gray-500 mt-1">15 caractères requis</p>
            </div>

            <!-- Info Box -->
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                <div class="flex">
                    <svg class="w-5 h-5 text-blue-600 mr-3 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                    </svg>
                    <div>
                        <h4 class="text-sm font-semibold text-blue-900 mb-1">Information importante</h4>
                        <p class="text-sm text-blue-800">Ce patient sera automatiquement lié à votre compte médecin. Vous serez le seul à pouvoir gérer ses prescriptions et son suivi médical.</p>
                    </div>
                </div>
            </div>

            <!-- Boutons -->
            <div class="flex justify-end space-x-3">
                <a asp-action="Patients" 
                   class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition duration-150">
                    Annuler
                </a>
                <button type="submit" 
                        class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition duration-150">
                    <span class="flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Créer le patient
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
