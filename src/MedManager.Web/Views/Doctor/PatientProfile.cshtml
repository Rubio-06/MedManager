@model MedManager.Web.Models.ViewModels.PatientProfileViewModel

@{
    ViewData["Title"] = $"Profil de {Model.FullName}";
    Layout = "_ManagementLayout";
}

<!-- Breadcrumb Navigation -->
<div class="flex items-center text-sm text-gray-600 mb-6">
    <a asp-action="Patients" class="hover:text-indigo-600 transition duration-150">Patients</a>
    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-900">@Model.FullName</span>
</div>

<div class="max-w-7xl mx-auto">
    <!-- Header avec actions -->
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Profil du Patient</h1>
            <p class="text-gray-600 mt-1">Informations détaillées et dossier médical</p>
        </div>
        <div class="flex space-x-3">
            <a asp-action="EditPatient" asp-route-id="@Model.Id" 
               class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition duration-150 font-medium inline-flex items-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                Modifier
            </a>
            <form asp-action="DeletePatient" asp-route-id="@Model.Id" method="post" class="inline" 
                  id="deletePatientForm" data-patient-name="@Model.FullName" data-prescription-count="@Model.PrescriptionCount">
                @Html.AntiForgeryToken()
                <button type="button" 
                        onclick="confirmPatientDeleteFromProfile(this.form)"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition duration-150 font-medium inline-flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    Supprimer
                </button>
            </form>
        </div>
    </div>

    <!-- Informations personnelles -->
    <div class="bg-white rounded-lg shadow mb-6">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-xl font-semibold text-gray-900">Informations personnelles</h2>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Avatar et nom -->
                <div class="md:col-span-3 flex items-center space-x-4 pb-6 border-b border-gray-200">
                    <div class="h-20 w-20 rounded-full bg-indigo-100 flex items-center justify-center">
                        <span class="text-3xl font-bold text-indigo-600">
                            @Model.FirstName.Substring(0, 1)@Model.LastName.Substring(0, 1)
                        </span>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-gray-900">@Model.FullName</h3>
                        <p class="text-gray-600">@Model.Age ans</p>
                    </div>
                </div>

                <!-- Informations détaillées -->
                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Email</label>
                    <p class="text-gray-900 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                        @Model.Email
                    </p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Date de naissance</label>
                    <p class="text-gray-900 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        @Model.DateBirthday.ToString("dd/MM/yyyy")
                    </p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Genre</label>
                    <p class="text-gray-900 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        @(Model.Gender == MedManager.Domain.Models.Users.Gender.Male ? "Masculin" : "Féminin")
                    </p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Numéro de sécurité sociale</label>
                    <p class="text-gray-900 flex items-center font-mono">
                        <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/>
                        </svg>
                        @Model.SocialSecurityNumber
                    </p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-500 mb-1">Statut du compte</label>
                    <p class="text-gray-900 flex items-center">
                        @if (Model.EmailConfirmed)
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                </svg>
                                Compte actif
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                </svg>
                                Compte inactif
                            </span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistiques rapides -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Allergies -->
        <div class="bg-white rounded-lg shadow">
            <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">Allergies</h2>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        @Model.Allergies.Count
                    </span>
                </div>
                <button onclick="openAllergyModal()" class="inline-flex items-center px-3 py-1.5 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition duration-150">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Ajouter
                </button>
            </div>
            <div class="p-6">
                <!-- Barre de recherche -->
                @if (Model.Allergies.Any())
                {
                    <div class="mb-4">
                        <div class="relative">
                            <input type="text" id="allergySearchProfile" placeholder="Rechercher dans les allergies..." 
                                   class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                                   onkeyup="filterProfileAllergies()">
                            <svg class="w-5 h-5 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </div>
                    </div>
                }
                @if (Model.Allergies.Any())
                {
                    <div class="overflow-hidden border border-gray-200 rounded-lg max-h-96 overflow-y-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Allergie
                                    </th>
                                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Description
                                    </th>
                                    <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        Action
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @foreach (var allergy in Model.Allergies)
                                {
                                    <tr class="hover:bg-gray-50 transition duration-150 allergy-row" 
                                        data-allergy-name="@allergy.Name.ToLower()" 
                                        data-allergy-description="@(allergy.Description?.ToLower() ?? "")">
                                        <td class="px-4 py-3 whitespace-nowrap">
                                            <div class="flex items-center">
                                                <svg class="w-5 h-5 text-red-500 mr-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                                </svg>
                                                <span class="font-medium text-gray-900">@allergy.Name</span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3">
                                            @if (!string.IsNullOrEmpty(allergy.Description))
                                            {
                                                <span class="text-sm text-gray-600">@allergy.Description</span>
                                            }
                                            else
                                            {
                                                <span class="text-sm text-gray-400 italic">Aucune description</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 whitespace-nowrap text-right">
                                            <button onclick="removeAllergy(@Model.Id, @allergy.Id, '@allergy.Name')" 
                                                    class="text-red-600 hover:text-red-800 transition duration-150 inline-flex items-center text-sm font-medium">
                                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                Retirer
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <p class="text-gray-600 mb-3">Aucune allergie connue</p>
                        <button onclick="openAllergyModal()" class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition duration-150">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            Ajouter la première allergie
                        </button>
                    </div>
                }
                <div id="noAllergyResults" class="hidden text-center py-8">
                    <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-gray-600">Aucune allergie correspondante</p>
                </div>
            </div>
        </div>

        <!-- Prescriptions -->
        <div class="bg-white rounded-lg shadow">
            <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <h2 class="text-lg font-semibold text-gray-900">Ordonnances</h2>
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-indigo-100 text-indigo-800">
                        @Model.PrescriptionCount
                    </span>
                </div>
                <a href="@Url.Action("CreatePrescription", "Doctor", new { patientId = Model.Id })" 
                   class="inline-flex items-center px-3 py-1.5 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition duration-150">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Créer une ordonnance
                </a>
            </div>
            <div class="p-6">
                @if (Model.PrescriptionCount == 0)
                {
                    <div class="text-center py-8">
                        <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                        <p class="text-gray-600 mb-3">Aucune ordonnance créée</p>
                        <a href="@Url.Action("CreatePrescription", "Doctor", new { patientId = Model.Id })" 
                           class="inline-flex items-center px-4 py-2 bg-green-600 text-white text-sm font-medium rounded-lg hover:bg-green-700 transition duration-150">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                            </svg>
                            Créer la première ordonnance
                        </a>
                    </div>
                }
                else
                {
                    <div class="space-y-6">
                        @foreach (var prescription in Model.Prescriptions)
                        {
                            <div class="border-2 border-gray-200 rounded-lg overflow-hidden">
                                <!-- En-tête de l'ordonnance -->
                                <div class="bg-indigo-50 px-4 py-3 flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="shrink-0 h-10 w-10 bg-indigo-600 rounded-lg flex items-center justify-center">
                                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="text-sm font-medium text-gray-900">Ordonnance du @prescription.DateCreated.ToString("dd/MM/yyyy")</div>
                                            <div class="text-xs text-gray-600">@prescription.DateCreated.ToString("HH:mm") - @prescription.Medicines.Count médicament@(prescription.Medicines.Count > 1 ? "s" : "")</div>
                                        </div>
                                    </div>
                                    <button onclick="deletePrescriptionFromProfile(@prescription.Id, '@prescription.DateCreated.ToString("dd/MM/yyyy")')" 
                                           class="text-red-600 hover:text-red-800 transition duration-150"
                                           title="Supprimer l'ordonnance">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </div>
                                
                                <!-- Tableau des médicaments -->
                                <div class="overflow-x-auto">
                                    <table class="min-w-full divide-y divide-gray-200">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                    Médicament
                                                </th>
                                                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                    Quantité
                                                </th>
                                                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                    Dosage
                                                </th>
                                                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                    Durée
                                                </th>
                                                <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                    Instructions
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody class="bg-white divide-y divide-gray-200">
                                            @foreach (var medicine in prescription.Medicines)
                                            {
                                                <tr class="hover:bg-gray-50">
                                                    <td class="px-4 py-3 whitespace-nowrap">
                                                        <div class="text-sm font-medium text-gray-900">@medicine.MedicineName</div>
                                                    </td>
                                                    <td class="px-4 py-3 whitespace-nowrap">
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                                            @medicine.Quantity
                                                        </span>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <div class="text-sm text-gray-900">@medicine.Dosage</div>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <div class="text-sm text-gray-600">
                                                            @if (!string.IsNullOrEmpty(medicine.Duration))
                                                            {
                                                                @medicine.Duration
                                                            }
                                                            else
                                                            {
                                                                <span class="text-gray-400 italic">-</span>
                                                            }
                                                        </div>
                                                    </td>
                                                    <td class="px-4 py-3">
                                                        <div class="text-sm text-gray-600 max-w-xs">
                                                            @if (!string.IsNullOrEmpty(medicine.Instructions))
                                                            {
                                                                @medicine.Instructions
                                                            }
                                                            else
                                                            {
                                                                <span class="text-gray-400 italic">-</span>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Actions rapides -->
    <div class="bg-white rounded-lg shadow">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-lg font-semibold text-gray-900">Actions rapides</h2>
        </div>
        <div class="p-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <button disabled class="flex items-center p-4 border-2 border-gray-200 rounded-lg hover:border-indigo-300 transition duration-150 cursor-not-allowed opacity-50">
                    <svg class="w-8 h-8 text-indigo-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <div class="text-left">
                        <p class="font-medium text-gray-900">Nouvelle ordonnance</p>
                        <p class="text-sm text-gray-600">Prochainement</p>
                    </div>
                </button>

                <button onclick="openAllergyModal()" class="flex items-center p-4 border-2 border-indigo-200 rounded-lg hover:border-indigo-400 hover:bg-indigo-50 transition duration-150 cursor-pointer">
                    <svg class="w-8 h-8 text-indigo-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    <div class="text-left">
                        <p class="font-medium text-gray-900">Ajouter allergie</p>
                        <p class="text-sm text-gray-600">Gérer les allergies</p>
                    </div>
                </button>

                <button disabled class="flex items-center p-4 border-2 border-gray-200 rounded-lg hover:border-indigo-300 transition duration-150 cursor-not-allowed opacity-50">
                    <svg class="w-8 h-8 text-indigo-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    <div class="text-left">
                        <p class="font-medium text-gray-900">Historique médical</p>
                        <p class="text-sm text-gray-600">Prochainement</p>
                    </div>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Ajouter Allergies -->
<div id="allergyModal" class="fixed inset-0 bg-black/50 z-50 items-center justify-center p-4" style="display: none;">
    <div class="bg-white rounded-lg shadow-xl max-w-2xl w-full max-h-[90vh] flex flex-col">
        <!-- Header -->
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
            <h3 class="text-xl font-semibold text-gray-900">Ajouter des Allergies</h3>
            <button onclick="closeAllergyModal()" class="text-gray-400 hover:text-gray-600 transition duration-150">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Search Bar -->
        <div class="px-6 py-4 border-b border-gray-200">
            <div class="relative">
                <input type="text" id="allergySearch" placeholder="Rechercher une allergie..." 
                       class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600"
                       onkeyup="filterAllergies()">
                <svg class="w-5 h-5 text-gray-400 absolute left-3 top-1/2 transform -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
            </div>
        </div>

        <!-- Liste des allergies -->
        <div class="flex-1 overflow-y-auto px-6 py-4">
            <div id="allergyList" class="space-y-2">
                @foreach (var allergy in Model.AvailableAllergies)
                {
                    var isAlreadyAdded = Model.Allergies.Any(a => a.Id == allergy.Id);
                    <div class="allergy-item p-3 border-2 rounded-lg transition duration-150 cursor-pointer @(isAlreadyAdded ? "border-gray-200 bg-gray-50 opacity-50 cursor-not-allowed" : "border-gray-200 hover:border-indigo-400 hover:bg-indigo-50")" 
                         data-allergy-id="@allergy.Id"
                         data-allergy-name="@allergy.Name.ToLower()" 
                         data-allergy-description="@allergy.Description?.ToLower()"
                         data-already-added="@isAlreadyAdded.ToString().ToLower()"
                         onclick="toggleAllergySelection(this)">
                        <div class="flex items-start">
                            <div class="ml-3 flex-1">
                                <p class="font-medium text-gray-900">@allergy.Name</p>
                                @if (!string.IsNullOrEmpty(allergy.Description))
                                {
                                    <p class="text-sm text-gray-600 mt-1">@allergy.Description</p>
                                }
                                @if (isAlreadyAdded)
                                {
                                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-800 mt-1">
                                        Déjà ajoutée
                                    </span>
                                }
                            </div>
                            @if (!isAlreadyAdded)
                            {
                                <div class="checkmark-icon hidden">
                                    <svg class="w-6 h-6 text-indigo-600" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            <div id="noResults" class="hidden text-center py-8">
                <svg class="w-12 h-12 text-gray-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <p class="text-gray-600">Aucune allergie trouvée</p>
            </div>
        </div>

        <!-- Footer avec boutons -->
        <div class="px-6 py-4 border-t border-gray-200 flex justify-end gap-3">
            <button onclick="closeAllergyModal()" class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 transition duration-150 font-medium">
                Annuler
            </button>
            <button onclick="addSelectedAllergies()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition duration-150 font-medium">
                Ajouter les allergies
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAllergyModal() {
            document.getElementById('allergyModal').style.display = 'flex';
            document.getElementById('allergySearch').value = '';
            // Réinitialiser les sélections
            document.querySelectorAll('.allergy-item').forEach(item => {
                if (item.getAttribute('data-already-added') !== 'true') {
                    item.classList.remove('border-indigo-600', 'bg-indigo-50');
                    item.classList.add('border-gray-200');
                    const checkmark = item.querySelector('.checkmark-icon');
                    if (checkmark) checkmark.classList.add('hidden');
                }
            });
            filterAllergies();
        }

        function closeAllergyModal() {
            document.getElementById('allergyModal').style.display = 'none';
        }

        function toggleAllergySelection(element) {
            // Ne pas permettre de sélectionner les allergies déjà ajoutées
            if (element.getAttribute('data-already-added') === 'true') {
                return;
            }

            const checkmark = element.querySelector('.checkmark-icon');
            
            if (element.classList.contains('border-indigo-600')) {
                // Désélectionner
                element.classList.remove('border-indigo-600', 'bg-indigo-50');
                element.classList.add('border-gray-200');
                if (checkmark) checkmark.classList.add('hidden');
            } else {
                // Sélectionner
                element.classList.remove('border-gray-200');
                element.classList.add('border-indigo-600', 'bg-indigo-50');
                if (checkmark) checkmark.classList.remove('hidden');
            }
        }

        function filterAllergies() {
            const searchTerm = document.getElementById('allergySearch').value.toLowerCase();
            const allergyItems = document.querySelectorAll('.allergy-item');
            let visibleCount = 0;

            allergyItems.forEach(item => {
                const name = item.getAttribute('data-allergy-name');
                const description = item.getAttribute('data-allergy-description') || '';
                
                if (name.includes(searchTerm) || description.includes(searchTerm)) {
                    item.style.display = '';
                    visibleCount++;
                } else {
                    item.style.display = 'none';
                }
            });

            document.getElementById('noResults').classList.toggle('hidden', visibleCount > 0);
        }

        function filterProfileAllergies() {
            const searchTerm = document.getElementById('allergySearchProfile').value.toLowerCase();
            const allergyRows = document.querySelectorAll('.allergy-row');
            let visibleCount = 0;

            allergyRows.forEach(row => {
                const name = row.getAttribute('data-allergy-name');
                const description = row.getAttribute('data-allergy-description') || '';
                
                if (name.includes(searchTerm) || description.includes(searchTerm)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            const table = document.querySelector('.allergy-row')?.closest('table')?.parentElement;
            const noResults = document.getElementById('noAllergyResults');
            
            if (table) {
                table.style.display = visibleCount > 0 ? '' : 'none';
            }
            if (noResults) {
                noResults.classList.toggle('hidden', visibleCount > 0 || searchTerm === '');
            }
        }

        function addSelectedAllergies() {
            const selectedItems = document.querySelectorAll('.allergy-item.border-indigo-600');
            const selectedIds = Array.from(selectedItems).map(item => parseInt(item.getAttribute('data-allergy-id')));

            if (selectedIds.length === 0) {
                alert('Veuillez sélectionner au moins une allergie');
                return;
            }

            // Récupérer le token CSRF depuis le formulaire de suppression existant
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            // Créer un FormData pour l'envoi
            const formData = new FormData();
            formData.append('patientId', @Model.Id);
            selectedIds.forEach(id => formData.append('allergyIds', id));
            formData.append('__RequestVerificationToken', token);

            // Envoyer la requête AJAX
            fetch('@Url.Action("AddAllergies", "Doctor")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Recharger la page pour afficher les nouvelles allergies
                    location.reload();
                } else {
                    alert(data.message || 'Erreur lors de l\'ajout des allergies');
                }
            })
            .catch(error => {
                console.error('Erreur:', error);
                alert('Erreur lors de l\'ajout des allergies');
            });
        }

        function removeAllergy(patientId, allergyId, allergyName) {
            showConfirmDialog(
                'Retirer l\'allergie',
                `Êtes-vous sûr de vouloir retirer l'allergie "<strong>${allergyName}</strong>" du dossier de ce patient ?<br><br>Cette action sera enregistrée dans l'historique.`,
                'Retirer',
                'Annuler',
                function() {
                    // Récupérer le token CSRF
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    // Créer un FormData
                    const formData = new FormData();
                    formData.append('patientId', patientId);
                    formData.append('allergyId', allergyId);
                    formData.append('__RequestVerificationToken', token);

                    // Envoyer la requête
                    fetch('@Url.Action("RemoveAllergy", "Doctor")', {
                        method: 'POST',
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert(data.message || 'Erreur lors de la suppression');
                        }
                    })
                    .catch(error => {
                        console.error('Erreur:', error);
                        alert('Erreur lors de la suppression de l\'allergie');
                    });
                }
            );
        }

        function confirmPatientDeleteFromProfile(form) {
            const patientName = form.getAttribute('data-patient-name');
            const prescriptionCount = parseInt(form.getAttribute('data-prescription-count'));
            
            if (prescriptionCount > 0) {
                showConfirmDialog(
                    'Suppression impossible',
                    `Impossible de supprimer "${patientName}" car ce patient possède ${prescriptionCount} prescription(s).<br><br>Veuillez d'abord supprimer toutes les prescriptions associées.`,
                    'J\'ai compris',
                    '',
                    function() {}
                );
            } else {
                showConfirmDialog(
                    'Confirmer la suppression',
                    `Êtes-vous sûr de vouloir supprimer le patient "${patientName}" ?<br><br>Cette action est irréversible et supprimera toutes les données associées.`,
                    'Supprimer',
                    'Annuler',
                    function() {
                        form.submit();
                    }
                );
            }
        }

        function deletePrescriptionFromProfile(prescriptionId, date) {
            showConfirmDialog(
                'Supprimer cette ordonnance ?',
                `Êtes-vous sûr de vouloir supprimer l'ordonnance du ${date} ? Cette action est irréversible.`,
                'Supprimer',
                'Annuler',
                function() {
                    // Créer le FormData
                    const formData = new FormData();
                    formData.append('prescriptionId', prescriptionId);

                    // Ajouter le token CSRF
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    
                    fetch('@Url.Action("DeletePrescription", "Doctor")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        },
                        body: formData
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            showToast(data.message, 'success');
                            // Recharger la page après un court délai
                            setTimeout(() => {
                                location.reload();
                            }, 1000);
                        } else {
                            showToast(data.message || 'Erreur lors de la suppression', 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showToast('Une erreur est survenue', 'error');
                    });
                }
            );
        }
    </script>
}
