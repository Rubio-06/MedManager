@model MedManager.Web.Models.ViewModels.UserInfoViewModel

@if (User.Identity?.IsAuthenticated == true)
{
    <!-- Sidebar -->
    <div class="fixed inset-y-0 left-0 w-64 bg-indigo-900 text-white">
        <div class="flex flex-col h-full">
            <!-- Logo -->
            <div class="flex items-center justify-center h-16 bg-indigo-950">
                <h1 class="text-2xl font-bold">MedManager</h1>
            </div>

            <!-- Navigation -->
            <nav class="flex-1 px-4 py-6 space-y-2 overflow-y-auto">
                @if (Model.Role == "Admin")
                {
                    <a asp-controller="Admin" asp-action="Dashboard" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Tableau de bord
                    </a>
                    <a asp-controller="Admin" asp-action="Users" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        Utilisateurs
                    </a>
                    <a asp-controller="Admin" asp-action="Medicines" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                        </svg>
                        Médicaments
                    </a>
                    <a asp-controller="Admin" asp-action="Allergies" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        Allergies
                    </a>
                }
                else if (Model.Role == "Doctor")
                {
                    <a asp-controller="Doctor" asp-action="Dashboard" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Tableau de bord
                    </a>
                    <a asp-controller="Doctor" asp-action="Patients" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                        </svg>
                        Mes Patients
                    </a>
                    <a asp-controller="Doctor" asp-action="Prescriptions" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Ordonnances
                    </a>
                }
                else if (Model.Role == "Patient")
                {
                    <a asp-controller="Patient" asp-action="Dashboard" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                        </svg>
                        Tableau de bord
                    </a>
                    <a asp-controller="Patient" asp-action="Profile" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        Mes Informations
                    </a>
                    <a asp-controller="Patient" asp-action="Prescriptions" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Mes Ordonnances
                    </a>
                    <a asp-controller="Patient" asp-action="MedicalHistory" class="sidebar-link">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        Mon Historique
                    </a>
                }
            </nav>

            <!-- User Info at Bottom with Dropup -->
            <div class="p-4 bg-indigo-950 border-t border-indigo-800 relative">
                <button id="userMenuButton" type="button" 
                        class="w-full flex items-center p-2 rounded-lg hover:bg-indigo-800 transition duration-150 cursor-pointer">
                    <div class="shrink-0 h-10 w-10 rounded-full bg-indigo-600 flex items-center justify-center">
                        <span class="text-white font-medium text-sm">
                            @(string.IsNullOrEmpty(Model.FirstName) ? "U" : Model.FirstName[0])@(string.IsNullOrEmpty(Model.LastName) ? "U" : Model.LastName[0])
                        </span>
                    </div>
                    <div class="ml-3 flex-1 text-left">
                        <div class="text-sm font-medium">@Model.FullName</div>
                        <div class="text-xs text-indigo-300">@Model.Role</div>
                    </div>
                    <svg class="w-5 h-5 text-indigo-300 transition-transform duration-200" id="userMenuIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                    </svg>
                </button>
                
                <!-- Dropup Menu -->
                <div id="userDropupMenu" 
                     class="absolute bottom-full left-0 right-0 mb-2 mx-4 bg-white rounded-lg shadow-xl border border-gray-200 overflow-hidden hidden">
                    <div class="py-1">
                        <div class="px-4 py-3 border-b border-gray-200">
                            <p class="text-sm font-medium text-gray-900">@Model.FullName</p>
                            <p class="text-xs text-gray-500 mt-1">@Model.Email</p>
                        </div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" 
                                    class="w-full text-left px-4 py-3 text-sm text-red-600 hover:bg-red-50 transition duration-150 flex items-center cursor-pointer">
                                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                </svg>
                                <span class="font-medium">Déconnexion</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Header -->
    <div class="fixed top-0 left-64 right-0 h-16 bg-white shadow-md z-10">
        <div class="h-full px-6 flex items-center justify-between">
            <div>
                <h2 class="text-xl font-semibold text-gray-800">@ViewData["Title"]</h2>
            </div>
        </div>
    </div>
}
else
{
    <!-- Simple header for non-authenticated users -->
    <nav class="bg-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="text-2xl font-bold text-indigo-600">MedManager</a>
                </div>
                <div class="flex items-center">
                    <a asp-controller="Account" asp-action="Login" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                        Se connecter
                    </a>
                </div>
            </div>
        </div>
    </nav>
}

<style>
    .sidebar-link {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: #E0E7FF;
        border-radius: 0.5rem;
        transition: all 0.15s;
        cursor: pointer;
    }

    .sidebar-link:hover {
        background-color: #4338CA;
        color: white;
    }

    .sidebar-link.active {
        background-color: #4F46E5;
        color: white;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const userMenuButton = document.getElementById('userMenuButton');
        const userDropupMenu = document.getElementById('userDropupMenu');
        const userMenuIcon = document.getElementById('userMenuIcon');

        if (userMenuButton && userDropupMenu) {
            // Toggle dropup menu
            userMenuButton.addEventListener('click', function(e) {
                e.stopPropagation();
                const isHidden = userDropupMenu.classList.contains('hidden');
                
                if (isHidden) {
                    userDropupMenu.classList.remove('hidden');
                    userMenuIcon.style.transform = 'rotate(180deg)';
                } else {
                    userDropupMenu.classList.add('hidden');
                    userMenuIcon.style.transform = 'rotate(0deg)';
                }
            });

            // Close dropup when clicking outside
            document.addEventListener('click', function(e) {
                if (!userMenuButton.contains(e.target) && !userDropupMenu.contains(e.target)) {
                    userDropupMenu.classList.add('hidden');
                    userMenuIcon.style.transform = 'rotate(0deg)';
                }
            });
        }
    });
</script>
