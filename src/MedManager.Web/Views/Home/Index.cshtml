@{
    ViewData["Title"] = "Accueil";
    Layout = "~/views/Shared/_LayoutAuth.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-500 to-purple-600">
    <div class="text-center">
        <h1 class="text-6xl font-bold text-white mb-4">MedManager</h1>
        <p class="text-xl text-white mb-8">Gestion médicale simplifiée</p>
        
        <div class="space-x-4">
            <a asp-controller="Account" asp-action="Login" 
               class="inline-flex items-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-indigo-600 bg-white hover:bg-gray-50 shadow-lg">
                Se connecter
            </a>
        </div>

        <div class="mt-12 bg-white/10 backdrop-blur-sm rounded-lg p-6 max-w-2xl mx-auto">
            <h2 class="text-2xl font-semibold text-white mb-4">Fonctionnalités</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 text-white">
                <div class="p-4">
                    <svg class="h-12 w-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <h3 class="font-semibold">Ordonnances</h3>
                    <p class="text-sm">Gestion complète des prescriptions</p>
                </div>
                <div class="p-4">
                    <svg class="h-12 w-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <h3 class="font-semibold">Patients</h3>
                    <p class="text-sm">Suivi personnalisé des patients</p>
                </div>
                <div class="p-4">
                    <svg class="h-12 w-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <h3 class="font-semibold">Historique</h3>
                    <p class="text-sm">Dossier médical complet</p>
                </div>
            </div>
        </div>
    </div>
</div>
