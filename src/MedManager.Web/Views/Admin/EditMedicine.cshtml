@model MedManager.Web.Models.ViewModels.EditMedicineViewModel

@{
    ViewData["Title"] = "Modifier le Médicament";
    Layout = "_ManagementLayout";
}

<div class="max-w-3xl mx-auto">
    <!-- Breadcrumb -->
    <div class="flex items-center text-sm text-gray-600 mb-6">
        <a asp-action="Medicines" class="hover:text-indigo-600 transition duration-150">Médicaments</a>
        <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class="text-gray-900">Modifier</span>
    </div>

    <!-- Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Modifier le Médicament</h1>
        <p class="mt-2 text-sm text-gray-600">Modifiez les informations du médicament</p>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <form asp-action="EditMedicine" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="text-red-600 mb-4"></div>

            <!-- Nom -->
            <div class="mb-6">
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
                <span asp-validation-for="Name" class="text-red-600 text-sm"></span>
            </div>

            <!-- Description -->
            <div class="mb-6">
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Description du médicament et de ses usages..."></textarea>
                <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
            </div>

            <!-- Dosage -->
            <div class="mb-6">
                <label asp-for="Dosage" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <input asp-for="Dosage" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Ex: 500mg, 2x par jour" />
                <span asp-validation-for="Dosage" class="text-red-600 text-sm"></span>
            </div>

            <!-- Effets secondaires -->
            <div class="mb-6">
                <label asp-for="SideEffects" class="block text-sm font-medium text-gray-700 mb-2"></label>
                <textarea asp-for="SideEffects" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Listez les effets secondaires possibles..."></textarea>
                <span asp-validation-for="SideEffects" class="text-red-600 text-sm"></span>
            </div>

            <!-- Boutons -->
            <div class="flex justify-end space-x-3">
                <a asp-action="Medicines" 
                   class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition duration-150">
                    Annuler
                </a>
                <button type="submit" 
                        class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition duration-150">
                    <span class="flex items-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Enregistrer les modifications
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
