@model List<MedManager.Web.Models.ViewModels.UserListItemViewModel>

@{
    ViewData["Title"] = "Gestion des Utilisateurs";
    Layout = "_ManagementLayout";
}

<div>
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Gestion des Utilisateurs</h1>
        <p class="text-gray-600 mt-1">Gérez tous les utilisateurs de la plateforme</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="shrink-0 bg-purple-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-gray-600 text-sm">Administrateurs</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.Count(u => u.Role == "Admin")</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="shrink-0 bg-blue-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-gray-600 text-sm">Médecins</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.Count(u => u.Role == "Doctor")</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="shrink-0 bg-green-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-gray-600 text-sm">Patients</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.Count(u => u.Role == "Patient")</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Barre de recherche, filtres et bouton -->
    <div class="mb-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
        <div class="flex flex-1 gap-3 flex-wrap">
            <!-- Barre de recherche -->
            <div class="relative flex-1 min-w-[250px]">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" 
                       id="searchInput" 
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 sm:text-sm transition duration-150"
                       placeholder="Rechercher un utilisateur (nom, email, rôle)...">
            </div>

            <!-- Dropdown Rôle -->
            <div class="relative">
                <button type="button" id="roleDropdownButton" 
                        class="inline-flex items-center justify-between w-full sm:w-48 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 transition duration-150">
                    <span id="roleDropdownText">Tous les rôles</span>
                    <svg class="w-4 h-4 ml-2 transition-transform duration-150" id="roleDropdownIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="roleDropdownMenu" class="hidden absolute z-10 mt-2 w-full sm:w-48 bg-white border border-gray-200 rounded-lg shadow-lg">
                    <ul class="py-1">
                        <li>
                            <button type="button" onclick="filterByRole('all')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Tous
                            </button>
                        </li>
                        <li>
                            <button type="button" onclick="filterByRole('Admin')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Administrateurs
                            </button>
                        </li>
                        <li>
                            <button type="button" onclick="filterByRole('Doctor')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Médecins
                            </button>
                        </li>
                        <li>
                            <button type="button" onclick="filterByRole('Patient')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Patients
                            </button>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Dropdown Tri -->
            <div class="relative">
                <button type="button" id="sortDropdownButton" 
                        class="inline-flex items-center justify-between w-full sm:w-32 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 transition duration-150">
                    <span id="sortDropdownText">A-Z</span>
                    <svg class="w-4 h-4 ml-2 transition-transform duration-150" id="sortDropdownIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="sortDropdownMenu" class="hidden absolute z-10 mt-2 w-full sm:w-32 bg-white border border-gray-200 rounded-lg shadow-lg">
                    <ul class="py-1">
                        <li>
                            <button type="button" onclick="sortUsers('asc')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                A-Z
                            </button>
                        </li>
                        <li>
                            <button type="button" onclick="sortUsers('desc')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Z-A
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Bouton Nouvel Utilisateur -->
        <a asp-action="CreateUser" 
           class="w-full sm:w-auto px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition duration-150 font-medium inline-flex items-center justify-center cursor-pointer shrink-0">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouvel Utilisateur
        </a>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-indigo-900">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Utilisateur
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Email
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Rôle
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Informations
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Statut
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-white uppercase tracking-wider">
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var user in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors" data-role="@user.Role">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="shrink-0 h-10 w-10">
                                    <div class="h-10 w-10 rounded-full @(user.Role == "Admin" ? "bg-purple-100 text-purple-600" : user.Role == "Doctor" ? "bg-blue-100 text-blue-600" : "bg-green-100 text-green-600") flex items-center justify-center font-semibold">
                                        @user.FirstName.Substring(0, 1).ToUpper()@user.LastName.Substring(0, 1).ToUpper()
                                    </div>
                                </div>
                                <div class="ml-4">
                                    <div class="text-sm font-medium text-gray-900">@user.FullName</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-900">@user.Email</div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                @(user.Role == "Admin" ? "bg-purple-100 text-purple-800" : 
                                  user.Role == "Doctor" ? "bg-blue-100 text-blue-800" : 
                                  "bg-green-100 text-green-800")">
                                @user.Role
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (user.Role == "Patient")
                            {
                                @if (!string.IsNullOrEmpty(user.DoctorName))
                                {
                                    <span class="text-xs">@user.DoctorName</span>
                                }
                                else
                                {
                                    <span class="text-xs text-gray-400">Pas de médecin assigné</span>
                                }
                            }
                            else if (user.Role == "Doctor" && user.PatientCount.HasValue)
                            {
                                <span class="text-xs">@user.PatientCount patients</span>
                            }
                            else
                            {
                                <span class="text-xs text-gray-400">—</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            @if (user.EmailConfirmed)
                            {
                                <span class="flex items-center text-xs text-green-600">
                                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                                    </svg>
                                    Actif
                                </span>
                            }
                            else
                            {
                                <span class="flex items-center text-xs text-gray-400">
                                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                    Inactif
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            @if (user.Role == "Admin")
                            {
                                <span class="inline-flex items-center px-3 py-1 rounded-md text-xs font-medium bg-purple-100 text-purple-800">
                                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
                                    </svg>
                                    Compte protégé
                                </span>
                            }
                            else
                            {
                                <div class="flex justify-end space-x-3">
                                    <a asp-action="EditUser" asp-route-id="@user.PersonId" 
                                       class="text-blue-600 hover:text-blue-900 transition duration-150"
                                       title="Modifier">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                        </svg>
                                    </a>
                                    <form asp-action="DeleteUser" asp-route-id="@user.PersonId" method="post" class="inline delete-form" data-user-name="@user.FullName">
                                        @Html.AntiForgeryToken()
                                        <button type="button" onclick="confirmUserDelete(this.form)" 
                                                class="text-red-600 hover:text-red-900 transition duration-150"
                                                title="Supprimer">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <div class="text-gray-500">
                                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <p class="mt-2 text-sm">Aucun utilisateur trouvé</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <!-- Message "Aucun résultat" pour la recherche -->
        <div id="noResults" style="display: none;" class="p-12 text-center">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Aucun résultat</h3>
            <p class="text-gray-600">Aucun utilisateur ne correspond à votre recherche.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmUserDelete(form) {
            const userName = form.getAttribute('data-user-name');
            
            showConfirmDialog(
                'Confirmer la suppression',
                `Êtes-vous sûr de vouloir supprimer l'utilisateur "${userName}" ?<br><br>Cette action est irréversible.`,
                'Supprimer',
                'Annuler',
                function() {
                    form.submit();
                }
            );
        }

        // Variables globales pour les filtres
        let currentRoleFilter = 'all';
        let currentSort = 'asc';

        // Gestion des dropdowns
        function toggleDropdown(dropdownId, buttonId, iconId) {
            const dropdown = document.getElementById(dropdownId);
            const icon = document.getElementById(iconId);
            const isHidden = dropdown.classList.contains('hidden');
            
            // Fermer tous les dropdowns
            document.querySelectorAll('[id$="DropdownMenu"]').forEach(menu => {
                if (menu.id !== dropdownId) {
                    menu.classList.add('hidden');
                }
            });
            
            // Réinitialiser tous les icônes
            document.querySelectorAll('[id$="DropdownIcon"]').forEach(ic => {
                if (ic.id !== iconId) {
                    ic.style.transform = 'rotate(0deg)';
                }
            });
            
            // Toggle le dropdown actuel
            if (isHidden) {
                dropdown.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                dropdown.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        }

        // Fonction de filtrage par rôle
        function filterByRole(role) {
            currentRoleFilter = role;
            
            // Mettre à jour le texte du dropdown
            const roleText = document.getElementById('roleDropdownText');
            if (role === 'all') {
                roleText.textContent = 'Tous les rôles';
            } else if (role === 'Admin') {
                roleText.textContent = 'Administrateurs';
            } else if (role === 'Doctor') {
                roleText.textContent = 'Médecins';
            } else {
                roleText.textContent = 'Patients';
            }
            
            // Fermer le dropdown
            document.getElementById('roleDropdownMenu').classList.add('hidden');
            document.getElementById('roleDropdownIcon').style.transform = 'rotate(0deg)';
            
            applyFilters();
        }

        // Fonction de tri
        function sortUsers(direction) {
            currentSort = direction;
            
            // Mettre à jour le texte du dropdown
            const sortText = document.getElementById('sortDropdownText');
            sortText.textContent = direction === 'asc' ? 'A-Z' : 'Z-A';
            
            // Fermer le dropdown
            document.getElementById('sortDropdownMenu').classList.add('hidden');
            document.getElementById('sortDropdownIcon').style.transform = 'rotate(0deg)';
            
            const tbody = document.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            
            rows.sort((a, b) => {
                const nameA = a.querySelector('.text-sm.font-medium').textContent.toLowerCase();
                const nameB = b.querySelector('.text-sm.font-medium').textContent.toLowerCase();
                return direction === 'asc' ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
            });
            
            rows.forEach(row => tbody.appendChild(row));
            applyFilters();
        }

        // Fonction d'application des filtres
        function applyFilters() {
            const searchInput = document.getElementById('searchInput');
            const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
            const tableRows = document.querySelectorAll('tbody tr');
            const noResultsMessage = document.getElementById('noResults');
            let visibleCount = 0;

            tableRows.forEach(row => {
                const rowText = row.textContent.toLowerCase();
                const role = row.getAttribute('data-role');
                
                // Vérifier le filtre de recherche
                const matchesSearch = searchTerm === '' || rowText.includes(searchTerm);
                
                // Vérifier le filtre de rôle
                let matchesRole = true;
                if (currentRoleFilter !== 'all') {
                    matchesRole = role === currentRoleFilter;
                }
                
                // Afficher ou masquer la ligne
                if (matchesSearch && matchesRole) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Afficher/masquer le message "Aucun résultat"
            if (noResultsMessage) {
                if (visibleCount === 0) {
                    noResultsMessage.style.display = '';
                } else {
                    noResultsMessage.style.display = 'none';
                }
            }
        }

        // Fonction de recherche
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            // Event listeners pour les dropdowns
            const roleDropdownButton = document.getElementById('roleDropdownButton');
            const sortDropdownButton = document.getElementById('sortDropdownButton');

            if (roleDropdownButton) {
                roleDropdownButton.addEventListener('click', function(e) {
                    e.stopPropagation();
                    toggleDropdown('roleDropdownMenu', 'roleDropdownButton', 'roleDropdownIcon');
                });
            }

            if (sortDropdownButton) {
                sortDropdownButton.addEventListener('click', function(e) {
                    e.stopPropagation();
                    toggleDropdown('sortDropdownMenu', 'sortDropdownButton', 'sortDropdownIcon');
                });
            }

            // Fermer les dropdowns quand on clique ailleurs
            document.addEventListener('click', function(e) {
                if (!e.target.closest('[id$="DropdownButton"]')) {
                    document.querySelectorAll('[id$="DropdownMenu"]').forEach(menu => {
                        menu.classList.add('hidden');
                    });
                    document.querySelectorAll('[id$="DropdownIcon"]').forEach(icon => {
                        icon.style.transform = 'rotate(0deg)';
                    });
                }
            });
        });
    </script>
}

