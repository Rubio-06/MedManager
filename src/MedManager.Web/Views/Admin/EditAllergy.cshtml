@model MedManager.Web.Models.ViewModels.EditAllergyViewModel

@{
    ViewData["Title"] = "Modifier une allergie";
    Layout = "_ManagementLayout";
}

<div>
    <div class="max-w-3xl mx-auto">
        <!-- En-tête -->
        <div class="mb-8">
            <div class="flex items-center text-sm text-gray-600 mb-4">
                <a asp-action="Allergies" class="hover:text-blue-600 transition duration-150">Allergies</a>
                <svg class="w-4 h-4 mx-2" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-gray-900">Modifier</span>
            </div>
            <h1 class="text-3xl font-bold text-gray-900">Modifier l'allergie</h1>
            <p class="mt-2 text-sm text-gray-600">
                Mettez à jour les informations de l'allergie.
            </p>
        </div>

        <!-- Formulaire -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <form asp-action="EditAllergy" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                
                <div asp-validation-summary="ModelOnly" class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg"></div>

                <!-- Nom -->
                <div class="mb-6">
                    <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-2">
                        Nom de l'allergie <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Name" 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-150"
                           placeholder="Ex: Pénicilline, Arachides, Lactose..."
                           maxlength="100" />
                    <span asp-validation-for="Name" class="text-red-500 text-sm mt-1"></span>
                </div>

                <!-- Description -->
                <div class="mb-6">
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-2">
                        Description
                    </label>
                    <textarea asp-for="Description" 
                              rows="4"
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition duration-150"
                              placeholder="Description détaillée de l'allergie, symptômes typiques, précautions..."
                              maxlength="500"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-sm mt-1"></span>
                    <p class="text-xs text-gray-500 mt-1">Maximum 500 caractères</p>
                </div>

                <!-- Warning Box -->
                <div class="mb-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
                    <div class="flex">
                        <div class="shrink-0">
                            <svg class="w-5 h-5 text-yellow-600" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-yellow-800">Attention</h3>
                            <p class="text-sm text-yellow-700 mt-1">
                                Les modifications seront appliquées à tous les patients et médicaments associés à cette allergie.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Boutons -->
                <div class="flex justify-end space-x-3">
                    <a asp-action="Allergies" 
                       class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition duration-150">
                        Annuler
                    </a>
                    <button type="submit" 
                            class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition duration-150">
                        <span class="flex items-center">
                            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            Enregistrer les modifications
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
