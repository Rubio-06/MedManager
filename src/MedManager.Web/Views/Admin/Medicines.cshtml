@model List<MedManager.Web.Models.ViewModels.MedicineListItemViewModel>

@{
    ViewData["Title"] = "Gestion des Médicaments";
    Layout = "_ManagementLayout";
}

<div>
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Gestion des Médicaments</h1>
        <p class="text-gray-600 mt-1">Gérez le catalogue de médicaments</p>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="shrink-0 bg-blue-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-gray-600 text-sm">Total Médicaments</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.Count</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex items-center">
                <div class="shrink-0 bg-green-100 rounded-lg p-3">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-gray-600 text-sm">Prescriptions Totales</p>
                    <p class="text-2xl font-bold text-gray-900">@Model.Sum(m => m.PrescriptionCount)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Barre de recherche, filtres et bouton -->
    <div class="mb-6 flex flex-col sm:flex-row gap-3 items-start sm:items-center justify-between">
        <div class="flex flex-1 gap-3 flex-wrap">
            <!-- Barre de recherche -->
            <div class="relative flex-1 min-w-[250px]">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" 
                       id="searchInput" 
                       class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:placeholder-gray-400 focus:ring-2 focus:ring-indigo-600 focus:border-indigo-600 hover:border-gray-400 sm:text-sm transition duration-150"
                       placeholder="Rechercher un médicament (nom, dosage, description)...">
            </div>

            <!-- Dropdown Tri Alphabétique -->
            <div class="relative">
                <button type="button" id="sortAlphaDropdownButton" 
                        class="inline-flex items-center justify-between w-full sm:w-36 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-600 transition duration-150">
                    <span id="sortAlphaDropdownText">A-Z</span>
                    <svg class="w-4 h-4 ml-2 transition-transform duration-150" id="sortAlphaDropdownIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div id="sortAlphaDropdownMenu" class="hidden absolute z-10 mt-2 w-full sm:w-36 bg-white border border-gray-200 rounded-lg shadow-lg">
                    <ul class="py-1">
                        <li>
                            <button type="button" onclick="sortMedicines('asc')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                A-Z
                            </button>
                        </li>
                        <li>
                            <button type="button" onclick="sortMedicines('desc')" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition duration-150">
                                Z-A
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Bouton Nouveau Médicament -->
        <a asp-action="CreateMedicine" 
           class="w-full sm:w-auto px-6 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition duration-150 font-medium inline-flex items-center justify-center cursor-pointer shrink-0">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
            </svg>
            Nouveau Médicament
        </a>
    </div>

    <!-- Medicines Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-indigo-900">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Médicament
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Description
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Dosage
                    </th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-white uppercase tracking-wider">
                        Prescriptions
                    </th>
                    <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-white uppercase tracking-wider">
                        Actions
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var medicine in Model)
                {
                    <tr class="hover:bg-gray-50 transition-colors" data-prescription-count="@medicine.PrescriptionCount">
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                                <div class="shrink-0 h-10 w-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                                    </svg>
                                </div>
                                <div class="ml-4">
                                    <div class="text-sm font-medium text-gray-900">@medicine.Name</div>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-900 max-w-xs truncate">
                                @(string.IsNullOrEmpty(medicine.Description) ? "—" : medicine.Description)
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm text-gray-900">
                                @(string.IsNullOrEmpty(medicine.Dosage) ? "—" : medicine.Dosage)
                            </div>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                @medicine.PrescriptionCount
                            </span>
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                            <div class="flex justify-end space-x-3">
                                <a asp-action="EditMedicine" asp-route-id="@medicine.Id" 
                                   class="text-blue-600 hover:text-blue-900 transition duration-150"
                                   title="Modifier">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <form asp-action="DeleteMedicine" asp-route-id="@medicine.Id" method="post" class="inline" data-medicine-name="@medicine.Name" data-prescription-count="@medicine.PrescriptionCount">
                                    @Html.AntiForgeryToken()
                                    <button type="button" onclick="confirmMedicineDelete(this.form)" 
                                            class="text-red-600 hover:text-red-900 transition duration-150"
                                            title="Supprimer">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center">
                            <div class="text-gray-500">
                                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                                </svg>
                                <p class="mt-2 text-sm">Aucun médicament trouvé</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        <!-- Message "Aucun résultat" pour la recherche -->
        <div id="noResults" style="display: none;" class="p-12 text-center">
            <svg class="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <h3 class="text-xl font-semibold text-gray-900 mb-2">Aucun résultat</h3>
            <p class="text-gray-600">Aucun médicament ne correspond à votre recherche.</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmMedicineDelete(form) {
            const medicineName = form.getAttribute('data-medicine-name');
            const prescriptionCount = parseInt(form.getAttribute('data-prescription-count'));
            
            if (prescriptionCount > 0) {
                showConfirmDialog(
                    'Suppression impossible',
                    `Impossible de supprimer "${medicineName}" car il est utilisé dans ${prescriptionCount} prescription(s).`,
                    'J\'ai compris',
                    '',
                    function() {}
                );
            } else {
                showConfirmDialog(
                    'Confirmer la suppression',
                    `Êtes-vous sûr de vouloir supprimer le médicament "${medicineName}" ?<br><br>Cette action est irréversible.`,
                    'Supprimer',
                    'Annuler',
                    function() {
                        form.submit();
                    }
                );
            }
        }

        // Variables globales pour les filtres
        let currentSort = 'asc';

        // Gestion des dropdowns
        function toggleDropdown(dropdownId, buttonId, iconId) {
            const dropdown = document.getElementById(dropdownId);
            const icon = document.getElementById(iconId);
            const isHidden = dropdown.classList.contains('hidden');
            
            // Toggle le dropdown actuel
            if (isHidden) {
                dropdown.classList.remove('hidden');
                icon.style.transform = 'rotate(180deg)';
            } else {
                dropdown.classList.add('hidden');
                icon.style.transform = 'rotate(0deg)';
            }
        }

        // Fonction de tri alphabétique
        function sortMedicines(direction) {
            currentSort = direction;
            
            // Mettre à jour le texte du dropdown alphabétique
            const sortAlphaText = document.getElementById('sortAlphaDropdownText');
            sortAlphaText.textContent = direction === 'asc' ? 'A-Z' : 'Z-A';
            
            // Fermer le dropdown
            document.getElementById('sortAlphaDropdownMenu').classList.add('hidden');
            document.getElementById('sortAlphaDropdownIcon').style.transform = 'rotate(0deg)';
            
            applySorting();
        }

        // Fonction d'application du tri
        function applySorting() {
            const tbody = document.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            
            rows.sort((a, b) => {
                const nameA = a.querySelector('.text-sm.font-medium').textContent.toLowerCase();
                const nameB = b.querySelector('.text-sm.font-medium').textContent.toLowerCase();
                return currentSort === 'asc' ? nameA.localeCompare(nameB) : nameB.localeCompare(nameA);
            });
            
            rows.forEach(row => tbody.appendChild(row));
            applyFilters();
        }

        // Fonction d'application des filtres de recherche
        function applyFilters() {
            const searchInput = document.getElementById('searchInput');
            const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
            const tableRows = document.querySelectorAll('tbody tr');
            const noResultsMessage = document.getElementById('noResults');
            let visibleCount = 0;

            tableRows.forEach(row => {
                const rowText = row.textContent.toLowerCase();
                
                // Vérifier le filtre de recherche
                const matchesSearch = searchTerm === '' || rowText.includes(searchTerm);
                
                // Afficher ou masquer la ligne
                if (matchesSearch) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Afficher/masquer le message "Aucun résultat"
            if (noResultsMessage) {
                if (visibleCount === 0) {
                    noResultsMessage.style.display = '';
                } else {
                    noResultsMessage.style.display = 'none';
                }
            }
        }

        // Fonction de recherche
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');

            if (searchInput) {
                searchInput.addEventListener('input', applyFilters);
            }

            // Event listener pour le dropdown
            const sortAlphaDropdownButton = document.getElementById('sortAlphaDropdownButton');

            if (sortAlphaDropdownButton) {
                sortAlphaDropdownButton.addEventListener('click', function(e) {
                    e.stopPropagation();
                    toggleDropdown('sortAlphaDropdownMenu', 'sortAlphaDropdownButton', 'sortAlphaDropdownIcon');
                });
            }

            // Fermer le dropdown quand on clique ailleurs
            document.addEventListener('click', function(e) {
                if (!e.target.closest('#sortAlphaDropdownButton')) {
                    const menu = document.getElementById('sortAlphaDropdownMenu');
                    const icon = document.getElementById('sortAlphaDropdownIcon');
                    if (menu) menu.classList.add('hidden');
                    if (icon) icon.style.transform = 'rotate(0deg)';
                }
            });
        });
    </script>
}
