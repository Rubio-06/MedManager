# App
ASPNETCORE_ENVIRONMENT=Production

# Single source of truth for database connectivity
CONNECTION_STRING=server=your-db-host;port=3306;database=medmanager;user=medmanager;password=your-password

# Startup retry for DB initialization
DB_INIT_MAX_RETRIES=10
DB_INIT_RETRY_DELAY_SECONDS=5

# Demo data in production (admin/doctor/patient + medicines + allergies)
SEED_DEMO_USERS=true
CLEANUP_LEGACY_DEMO_USERS=true
