# App
ASPNETCORE_ENVIRONMENT=Production

# Option 1: explicit connection string for Coolify or an external database
CONNECTION_STRING=server=db;port=3306;database=medmanager;user=root;password=medmanager

# Option 2: local Docker / Coolify service values
DB_HOST=db
DB_PORT=3306
DB_NAME=medmanager
DB_USER=root
DB_PASSWORD=medmanager

# Optional MySQL/MariaDB env vars for the db container
MYSQL_ROOT_PASSWORD=medmanager
MYSQL_DATABASE=medmanager

# Startup retry for DB initialization
DB_INIT_MAX_RETRIES=10
DB_INIT_RETRY_DELAY_SECONDS=5
