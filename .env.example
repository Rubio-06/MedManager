# App
ASPNETCORE_ENVIRONMENT=Production

# Option 1: explicit connection string for Coolify or an external database
CONNECTION_STRING=server=localhost;port=3306;database=medmanager;user=root;password=medmanager

# Option 2: local MariaDB values used by docker-compose when CONNECTION_STRING is not set
MYSQL_ROOT_PASSWORD=medmanager
MYSQL_DATABASE=medmanager

# Startup retry for DB initialization
DB_INIT_MAX_RETRIES=10
DB_INIT_RETRY_DELAY_SECONDS=5
